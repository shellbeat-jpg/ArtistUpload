<!DOCTYPE html>
<html lang="<%= lng %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dashboard — <%= t('common.stationName') %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="wrap">
    <div class="lang-switch" style="text-align:right; font-size:12px; margin-bottom:8px;">
        <a href="?lng=de">DE</a> · <a href="?lng=en">EN</a>
    </div>
    <div class="eyebrow"><%= t('common.stationName') %></div>
    <h1><%= artist.name %></h1>
    <p class="subtitle"><%= t('dashboard.subtitle') %></p>

    <% if (message) { %><div class="msg ok"><%= message %></div><% } %>
    <% if (error) { %><div class="msg error"><%= error %></div><% } %>

    <script>
        // Wird nach Auswahl einer Audiodatei aufgerufen: BPM-Feld waehrend der
        // Analyse inaktiv setzen, Datei zur Analyse an den Server schicken,
        // erkannten Wert (ganzzahlig) eintragen und Feld wieder freigeben.
        //
        // submitButtonId ist optional (drittes Argument): wird sie angegeben,
        // bleibt der zugehoerige Submit-Button waehrend der laufenden Analyse
        // inaktiv (mit Label aus data-label-analyzing), damit ein Abschicken
        // des Formulars vor Abschluss der Erkennung nicht mehr moeglich ist.
        // Das BPM-Ergebnis kaeme sonst erst nach dem Submit an und ginge
        // verloren. Die Labels kommen bewusst aus data-Attributen (statt
        // hartkodiertem Text im Script), damit sie mit dem Template
        // uebersetzt werden koennen.
        function wireBpmDetection(fileInputId, bpmInputId, submitButtonId) {
            var fileInput = document.getElementById(fileInputId);
            var bpmInput = document.getElementById(bpmInputId);
            var submitButton = submitButtonId ? document.getElementById(submitButtonId) : null;
            if (!fileInput || !bpmInput) return;

            fileInput.addEventListener('change', function () {
                if (!fileInput.files || !fileInput.files[0]) return;

                bpmInput.disabled = true;
                bpmInput.value = '';

                var originalButtonLabel = null;
                if (submitButton) {
                    originalButtonLabel = submitButton.textContent;
                    submitButton.disabled = true;
                    submitButton.textContent = submitButton.dataset.labelAnalyzing || originalButtonLabel;
                }

                var formData = new FormData();
                formData.append('track', fileInput.files[0]);

                fetch('/tracks/analyze-bpm', { method: 'POST', body: formData })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (data && data.bpm) {
                            bpmInput.value = data.bpm;
                        }
                    })
                    .catch(function () { /* Erkennung fehlgeschlagen -- Feld bleibt manuell nutzbar */ })
                    .finally(function () {
                        bpmInput.disabled = false;
                        if (submitButton) {
                            submitButton.disabled = false;
                            submitButton.textContent = originalButtonLabel;
                        }
                    });
            });
        }
    </script>

    <!-- Kontingent -->
    <div class="panel">
        <div class="quota-label">
            <span><%= t('dashboard.quotaLabel') %></span>
            <span><%= usedMb %> MB / <%= quotaMb %> MB</span>
        </div>
        <div class="quota-bar">
            <div class="quota-bar-fill <%= percentUsed > 90 ? 'danger' : (percentUsed > 70 ? 'warn' : '') %>"
                 style="width: <%= percentUsed %>%;"></div>
        </div>
    </div>

    <!-- Profil -->
    <h2><%= t('dashboard.profileHeading') %></h2>
    <div class="panel">
        <form method="POST" action="/profile">
            <label for="name"><%= t('dashboard.artistName') %></label>
            <input type="text" id="name" name="name" value="<%= artist.name %>" required>
                 <!--       -->
            <label for="artist_page_url"><%= t('dashboard.artistPageUrl') %></label>
            <input type="text" id="artist_page_url" name="artist_page_url" value="<%= artist.artist_page_url || '' %>" placeholder="https://..." required>
           
            <label for="bio"><%= t('dashboard.bio') %></label>
            <textarea id="bio" name="bio" rows="3" style="width:100%; background:#0a0a0d; border:1px solid var(--panel-border); color:var(--text); padding:10px 12px; border-radius:3px; font-family:var(--font-mono); font-size:14px;"><%= artist.bio || '' %></textarea>
                              
            <label for="email"><%= t('login.email') %></label>
            <input type="email" id="email" name="email" value="<%= artist.email || '' %>">
            
                            <!--
            <label for="contact_phone"><%= t('dashboard.contactPhone') %></label>
            <input type="text" id="contact_phone" name="contact_phone" value="<%= artist.contact_phone || '' %>">
                  
            <p class="hint"><%= t('dashboard.contactHint') %></p>
                    -->
            <label><%= t('dashboard.linksHeading') %></label>
                <!--
            <p class="hint"><%= t('dashboard.linksHint') %></p>
                      -->
            <% for (let i = 0; i < 3; i++) {
                const slot = artistLinkSlots[i];
            %>
                <div style="display:flex; gap:8px; margin-bottom:8px;">
                    <select name="link_platform_<%= i + 1 %>" style="flex:0 0 150px;">
                        <option value=""><%= t('dashboard.linkPlatformNone') %></option>
                        <% linkPlatforms.forEach(function(platform) { %>
                            <option value="<%= platform %>" <%= (slot && slot.platform === platform) ? 'selected' : '' %>>
                                <%= t('platforms.' + platform) %>
                            </option>
                        <% }); %>
                    </select>
                    <input type="text" name="link_url_<%= i + 1 %>" placeholder="https://..." style="flex:1;"
                           value="<%= slot ? slot.url : '' %>">
                </div>
            <% } %>

            <button type="submit" class="btn-quiet"><%= t('dashboard.saveProfile') %></button>
        </form>
    </div>

    <!-- Neuer Upload -->
    <h2><%= t('dashboard.uploadHeading') %></h2>
    <div class="panel">
        <form method="POST" action="/tracks/upload" enctype="multipart/form-data">
            <label for="title"><%= t('dashboard.trackName') %></label>
            <input type="text" id="title" name="title" required>

            <label for="genre"><%= t('dashboard.genre') %></label>
            <input type="text" id="genre" name="genre" required>

            <label for="bpm"><%= t('dashboard.bpmOptional') %></label>
            <input type="number" id="bpm" name="bpm" min="1" disabled>

            <label for="track_page_url"><%= t('dashboard.trackPageUrl') %></label>
            <input type="text" id="track_page_url" name="track_page_url" placeholder="https://..." required>

            <label for="video_url"><%= t('dashboard.videoUrlOptional') %></label>
            <input type="text" id="video_url" name="video_url" placeholder="https://...">

            <label for="bio_lyrics"><%= t('dashboard.bioLyrics') %></label>
            <textarea id="bio_lyrics" name="bio_lyrics" rows="4" style="width:100%; background:#0a0a0d; border:1px solid var(--panel-border); color:var(--text); padding:10px 12px; border-radius:3px; font-family:var(--font-mono); font-size:14px;"></textarea>

            <label for="track"><%= t('dashboard.audioFile') %></label>
            <input type="file" id="track" name="track" accept="audio/*" required>

            <label for="image"><%= t('dashboard.trackImage') %></label>
            <input type="file" id="image" name="image" accept="image/*" required>

            <button type="submit" id="upload-submit" data-label-analyzing="<%= t('dashboard.analyzing') %>"><%= t('dashboard.uploadSubmit') %></button>
        </form>
    </div>
    <script>wireBpmDetection('track', 'bpm', 'upload-submit');</script>

    <!-- Track-Liste -->
    <h2><%= t('dashboard.tracksHeading') %></h2>
    <% if (tracks.length === 0) { %>
        <div class="panel"><p class="hint"><%= t('dashboard.noTracks') %></p></div>
    <% } %>

    <% tracks.forEach(function(track) { %>
        <div class="panel">
            <div style="display:flex; gap:16px;">
                <% if (track.image_filename) { %>
                    <img src="/track-images/<%= track.image_filename %>" alt=""
                         style="width:72px; height:72px; object-fit:cover; border-radius:3px; border:1px solid var(--panel-border);">
                <% } %>
                <div style="flex:1;">
                    <div style="display:flex; justify-content:space-between; align-items:start;">
                        <div>
                            <strong><%= track.title %></strong>
                            <div class="hint"><%= track.genre %><% if (track.bpm) { %> · <%= track.bpm %> BPM<% } %></div>
                        </div>
                        <span class="status <%= track.status %>"><%= t('status.' + track.status, { defaultValue: track.status }) %></span>
                    </div>
                    <% if (track.status === 'abgelehnt' && track.reject_reason) { %>
                        <p class="hint" style="color: var(--danger);"><%= t('dashboard.rejectReason') %> <%= track.reject_reason %></p>
                    <% } %>
                    <p class="hint">
                        <%= (track.filesize_mb).toFixed(1) %> MB ·
                        <%= new Date(track.uploaded_at).toLocaleDateString(lng === 'en' ? 'en-GB' : 'de-DE') %>
                        <% if (track.track_page_url) { %> · <a href="<%= track.track_page_url %>" target="_blank" rel="noopener noreferrer"><%= t('dashboard.trackPageLink') %></a><% } %>
                        <% if (track.video_url) { %> · <a href="<%= track.video_url %>" target="_blank" rel="noopener noreferrer"><%= t('dashboard.videoLink') %></a><% } %>
                    </p>
                </div>
            </div>

            <details style="margin-top: 12px;">
                <summary style="cursor:pointer; font-size:12px; color: var(--text-dim);"><%= t('dashboard.editExpand') %></summary>
                <form method="POST" action="/tracks/<%= track.id %>/replace" enctype="multipart/form-data" style="margin-top:12px;">
                    <label><%= t('dashboard.trackName') %></label>
                    <input type="text" name="title" value="<%= track.title %>" required>

                    <label><%= t('dashboard.genre') %></label>
                    <input type="text" name="genre" value="<%= track.genre %>" required>

                    <label><%= t('dashboard.bpmOptional') %></label>
                    <input type="number" name="bpm" id="replace-bpm-<%= track.id %>" min="1" value="<%= track.bpm || '' %>">

                    <label><%= t('dashboard.trackPageUrl') %></label>
                    <input type="text" name="track_page_url" value="<%= track.track_page_url || '' %>" required>

                    <label><%= t('dashboard.videoUrlOptional') %></label>
                    <input type="text" name="video_url" value="<%= track.video_url || '' %>">

                    <label><%= t('dashboard.bioLyrics') %></label>
                    <textarea name="bio_lyrics" rows="3" style="width:100%; background:#0a0a0d; border:1px solid var(--panel-border); color:var(--text); padding:10px 12px; border-radius:3px; font-family:var(--font-mono); font-size:14px;"><%= track.bio_lyrics || '' %></textarea>

                    <label><%= t('dashboard.newAudioOptional') %></label>
                    <input type="file" name="track" id="replace-track-<%= track.id %>" accept="audio/*">

                    <label><%= t('dashboard.newImageOptional') %></label>
                    <input type="file" name="image" accept="image/*">

                    <div class="track-actions">
                        <button type="submit" class="btn-small" id="replace-submit-<%= track.id %>" data-label-analyzing="<%= t('dashboard.analyzing') %>"><%= t('dashboard.save') %></button>
                    </div>
                </form>
                <script>wireBpmDetection('replace-track-<%= track.id %>', 'replace-bpm-<%= track.id %>', 'replace-submit-<%= track.id %>');</script>
            </details>

            <form method="POST" action="/tracks/<%= track.id %>/delete"
                  onsubmit="return confirm('<%= t('dashboard.deleteConfirm') %>');" style="margin-top:8px;">
                <button type="submit" class="btn-danger btn-small"><%= t('dashboard.delete') %></button>
            </form>
        </div>
    <% }); %>

    <form method="POST" action="/logout" style="margin-top: 32px;">
        <button type="submit" class="btn-quiet btn-small"><%= t('dashboard.logout') %></button>
    </form>
</div>
</body>
</html>
