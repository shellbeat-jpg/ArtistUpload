<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login — Luziferase Upload</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="wrap" style="max-width: 420px; padding-top: 96px;">
        <div class="eyebrow">Luziferase on Air</div>
        <h1>Artist-Login</h1>
        <p class="subtitle">Zugang zur Verwaltung deiner Tracks.</p>

        <div class="panel">
            <% if (error) { %>
                <div class="msg error"><%= error %></div>
            <% } %>
            <form method="POST" action="/login">
                <label for="email">E-Mail</label>
                <input type="email" id="email" name="email" required autofocus>

                <label for="password">Passwort</label>
                <input type="password" id="password" name="password" required>

                <button type="submit">Anmelden</button>
            </form>
        </div>

        <a class="footer-link" href="/admin/login">Admin-Login →</a>
    </div>
</body>
</html>
