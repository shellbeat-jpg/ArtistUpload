<!DOCTYPE html>
<html lang="<%= lng %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= t('register.title') %> — <%= t('common.stationName') %></title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body>
<div class="wrap">
    <!-- Sprachumschalter -->
    <div class="lang-switch" style="text-align:right; font-size:12px; margin-bottom:8px;">
        <a href="?lng=de">DE</a> · <a href="?lng=en">EN</a>
    </div>
    
    <div class="eyebrow"><%= t('common.stationName') %></div>
    <h1><%= t('login.register_button') %></h1>
    <p class="subtitle"><%= t('register.title') %></p>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="msg error"><%= error %></div>
    <% } %>  

    <!-- Profil-Informationen -->
    <h2><%= t('dashboard.profileHeading') %></h2>
    <div class="panel">
        <form method="POST" action="/register">
            
            <label for="artist_name"><%= t('dashboard.artistName') %> *</label>
            <input type="text" id="artist_name" name="artist_name" value="<%= formData.artist_name || '' %>" required autocomplete="username">

            <label for="email"><%= t('dashboard.contactEmail') %> *</label>
            <input type="email" id="email" name="email"  value="<%= formData.email || '' %>" required autocomplete="email">

            <label for="contact_phone"><%= t('dashboard.contactPhone') || 'Kontakt Telefon (optional)' %></label>
            <input type="text" id="contact_phone" name="contact_phone" value="<%= formData.contact_phone || '' %>">

            <label for="artist_page_url"><%= t('dashboard.artistPageUrl') %> *</label>
            <input type="text" id="artist_page_url" name="artist_page_url" value="<%= formData.artist_page_url || '' %>"  placeholder="https://..." required>

            <label for="bio"><%= t('dashboard.bio') %></label>
            <textarea id="bio" name="bio" rows="3" style="width:100%; background:#0a0a0d; border:1px solid var(--panel-border); color:var(--text); padding:10px 12px; border-radius:3px; font-family:var(--font-mono); font-size:14px;"><%= formData.bio || '' %></textarea>

            <p class="hint" style="margin-top: 12px; margin-bottom: 24px;"><%= t('dashboard.contactHint') %></p>

            <!-- Links-Muster für Streaming-Plattformen -->
            <label><%= t('dashboard.linksHeading') %></label>
            <p class="hint" style="margin-bottom: 12px;"><%= t('dashboard.linksHint') %></p>
            
            <% for (let i = 0; i < 3; i++) { 
                const submittedPlatform = formData['link_platform_' + (i + 1)] || '';
                const submittedUrl = formData['link_url_' + (i + 1)] || '';
            %>
                <div style="display:flex; gap:8px; margin-bottom:8px;">
                    <select name="link_platform_<%= i + 1 %>" style="flex:0 0 150px;">
                        <option value=""><%= t('dashboard.linkPlatformNone') %></option>
                        <% linkPlatforms.forEach(function(platform) { %>
                            <option value="<%= platform %>"  <%= submittedPlatform === platform ? 'selected' : '' %>>
                                <%= t('platforms.' + platform) %>
                            </option>
                        <% }); %>
                    </select>
                    <input type="text" name="link_url_<%= i + 1 %>" placeholder="https://..." style="flex:1;" value="<%= submittedUrl %>">
                </div>
            <% } %>

            <!-- Sicherheit & Passwort -->
            <h2 style="margin: 32px 0 12px 0; padding: 0; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 1px;"><%= t('register.section_security') %></h2>
            
            <label for="password"><%= t('register.password') %> *</label>
            <input type="password" id="password" name="password" required autocomplete="new-password">

            <label for="password_confirm"><%= t('register.password_confirm') %> *</label>
            <input type="password" id="password_confirm" name="password_confirm" required autocomplete="new-password">

            <!-- Cloudflare Turnstile "Ich-bin-ein-Mensch"-Authentifizierung -->
            <div style="margin: 24px 0; display: flex; justify-content: center;">
                <div class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="dark"></div>
            </div>

            <!-- Buttons passend zur CSS-Nomenklatur -->
            <div style="display: flex; gap: 12px; align-items: center; margin-top: 16px;">
                <button type="submit"><%= t('register.submit') %></button>
                <a href="/login" class="btn-quiet btn-small" style="text-decoration: none; display: inline-block;"><%= t('register.back_to_login') %></a>
            </div>
        </form>
    </div>
</div>
</body>
</html>
