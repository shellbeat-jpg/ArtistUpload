# Session-Geheimnis (langen, zufaelligen String einsetzen)
SESSION_SECRET=bitte-aendern-zu-langem-zufallsstring

# Port, auf dem diese Anwendung lokal lauscht (Reverse Proxy leitet z.B. von
# uploads.luziferase.de auf 127.0.0.1:PORT weiter)
PORT=3500

# --- AzuraCast API ---
# API-Key erzeugen unter: AzuraCast -> Nutzermenue -> "Meine API-Schluessel"
AZURACAST_BASE_URL=https://azuracast.luziferase.de
AZURACAST_API_KEY=
AZURACAST_STATION_ID=1

# Admin-Zugangsdaten fuer den erstmaligen Login (Artist-Accounts legst du danach
# im Admin-Bereich selbst an)
ADMIN_EMAIL=admin@luziferase.de
ADMIN_PASSWORD=bitte-aendern

# Erlaubte Datei-Endungen (kommasepariert)
ALLOWED_EXTENSIONS=flac,wav,mp3

# Max. Einzeldateigroesse in MB (unabhaengig vom Gesamt-Kontingent)
MAX_FILE_SIZE_MB=300
